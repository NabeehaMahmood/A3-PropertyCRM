# MongoDB
# Connection string for your MongoDB database
# Example: mongodb+srv://username:password@cluster.mongodb.net/property-crm
MONGODB_URI=mongodb://localhost:27017/property-crm

# JWT Secret
# Generate a strong random string for JWT token signing
# Run: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# SMTP Email Settings (for Gmail)
# SMTP Host: smtp.gmail.com
SMTP_HOST=smtp.gmail.com
# SMTP Port: 587 (TLS) or 465 (SSL)
SMTP_PORT=587
# Your Gmail address (e.g., your-email@gmail.com)
SMTP_USER=your-email@gmail.com
# App Password (NOT your email password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password

# App URL (for production)
# Example: https://propertycrm.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000